# PostgreSQL
APP_ENV=production
POSTGRES_USER=razorscope
POSTGRES_PASSWORD=<openssl rand -base64 32>
POSTGRES_DB=razorscope
DATABASE_URL=postgresql://razorscope_app:<app_password>@postgres:5432/razorscope

# ClickHouse
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PASSWORD=<openssl rand -base64 32>
CLICKHOUSE_USER=razorscope
CLICKHOUSE_DB=razorscope

# OpenAI
OPENAI_API_KEY=sk-...

# JWT (MUST be 32+ random bytes)
JWT_SECRET_KEY=<python3 -c "import secrets; print(secrets.token_hex(32))">
RAZORPAY_SECRET_ENCRYPTION_KEY=<python3 -c "import secrets; print(secrets.token_hex(32))">
REFRESH_COOKIE_SECURE=true

# Frontend
VITE_API_BASE=https://api.yourdomain.com
CORS_ORIGINS=https://app.yourdomain.com
WEBHOOK_BASE_URL=https://webhooks.yourdomain.com

# Kafka (generate once: python3 -c "import uuid, base64; print(base64.b64encode(uuid.uuid4().bytes).decode())")
KAFKA_CLUSTER_ID=<base64-encoded-uuid>

# Grafana
GF_SECURITY_ADMIN_PASSWORD=<openssl rand -base64 24>
