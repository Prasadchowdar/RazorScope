# ─── Copy this file to .env and fill in the values ───────────────────────────
# docker compose automatically loads .env from this directory

APP_ENV=development

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://razorscope:razorscope_dev@localhost:5432/razorscope?sslmode=disable

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ─── Kafka ───────────────────────────────────────────────────────────────────
# Use port 29092 (external listener) when running services on host
KAFKA_BROKERS=localhost:29092
KAFKA_TOPIC=razorpay.events
KAFKA_WRITE_TIMEOUT=2s

# ─── Webhook Receiver ────────────────────────────────────────────────────────
PORT=8080
WEBHOOK_BASE_URL=http://localhost:8080
RAZORPAY_SECRET_ENCRYPTION_KEY=razorscope-dev-razorpay-secret
TIMESTAMP_TOLERANCE_SEC=300
LOG_LEVEL=info

# ─── ClickHouse ──────────────────────────────────────────────────────────────
CLICKHOUSE_ADDR=localhost:9000
CLICKHOUSE_USER=razorscope
CLICKHOUSE_PASSWORD=razorscope_dev
CLICKHOUSE_DB=razorscope

# ─── OpenAI (required for AI agent features) ─────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
# docker compose reads this and injects it into the api container automatically
OPENAI_API_KEY=your-openai-api-key-here

# ─── Dev seed merchant ───────────────────────────────────────────────────────
DEV_MERCHANT_ID=11111111-1111-1111-1111-111111111111
DEV_WEBHOOK_SECRET=whsec_dev_test_secret
